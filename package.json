{
  "name": "ride-the-bus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:online": "npm run build && node server-dist/onlineServer.mjs",
    "build": "npm run typecheck && vite build && npm run build:server",
    "build:server": "node scripts/build-server.mjs",
    "start": "node server-dist/onlineServer.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e:api",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e:api": "npm run build && node test/e2e/e2e-smoke.mjs",
    "test:e2e:browser": "playwright test",
    "test:e2e": "npm run test:e2e:api && npm run test:e2e:browser",
    "test:watch": "vitest",
    "lint": "eslint .",
    "audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.4.3",
    "typescript": "^5.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.10",
    "@playwright/test": "^1.55.0"
  }
}
