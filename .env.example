# Public host handled by Caddy/DuckDNS, for example: my-party-room.duckdns.org
RIDE_THE_BUS_DOMAIN=your-name.duckdns.org

# Optional shared code required for new online joins. Leave empty for LAN/offline-only use.
ROOM_ACCESS_CODE=

# Online room size cap. Keep this modest on a Raspberry Pi.
MAX_PLAYERS=12
